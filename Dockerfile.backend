FROM python:3.12-slim
WORKDIR /app
COPY server.py .
# Create /data dir — Railway volume will mount here, but this ensures
# the path exists even without a volume (uses container-local storage)
RUN mkdir -p /data
# Railway sets $PORT dynamically — don't hardcode it
ENV DB_PATH=/data/subscribers.db
EXPOSE 8080
CMD ["python", "-u", "server.py"]
